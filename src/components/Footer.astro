---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const allCategories = posts.flatMap(post => post.data.categories || (post.data.category ? [post.data.category] : []));
const uniqueCategories = [...new Set(allCategories)];

const categoryMap: Record<string, string> = {
  'roam': '漫遊',
  'walk': '行路',
  'guide': '路引'
};

const today = new Date();
---
<footer>
  <div class="footer-container">
    <div class="footer-main">
      <div class="footer-intro">
        <h3>迷走客</h3>
        <p>跟隨迷走的文字，穿越時空的限制，展開一場充滿冒險與想像的旅程。
我將帶你探索最真實的人生故事，從內心深處觸發靈感的火花，彷彿經歷了一場場驚心動魄的探險。
讓文字帶領你穿越每一個故事的情節，感受生命中最精彩的瞬間。</p>
      </div>
      <div class="footer-menus">
        <div class="footer-menu">
          <h4>全站分類</h4>
          <ul>
            {uniqueCategories.slice(0, 5).map(category => (
              <li><a href={`/categories/${category}`}>{categoryMap[category.toLowerCase()] || category}</a></li>
            ))}
            {uniqueCategories.length > 5 && <li><a href="/categories">...更多</a></li>}
          </ul>
        </div>
        <div class="footer-menu">
          <h4>Site Information</h4>
          <ul>
            <li><a href="/about">About Us</a></li>
            <li><a href="/contact">Contact Us</a></li>
            <li><a href="/privacy">Privacy Policy</a></li>
            <li><a href="/search">Site Search</a></li>
          </ul>
        </div>
        <div class="footer-menu">
          <h4>Support Us</h4>
          <ul>
            <li><a href="https://mounx.com/s/buyMacoffee" rel="nofollow noopener noreferrer" target="_blank">❤️ Donate</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="copyright">&copy; {today.getFullYear()} 迷走客. Powered by <a href="https://mountos.com/" target="_blank">Mountos</a>.</p>
      <div class="footer-socials">
        <a href="https://www.facebook.com/Mizuc/" class="social-link" aria-label="Facebook" rel="nofollow noopener noreferrer" target="_blank">
