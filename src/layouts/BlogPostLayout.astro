---
import Layout from './Layout.astro';
import ToC from '../components/ToC.astro';
const { frontmatter, headings } = Astro.props;

const hasHeadings = headings.filter(h => h.depth > 1 && h.depth < 4).length > 0;
const primaryCategory = frontmatter.categories?.[0] || frontmatter.category;
const categoryMap: Record<string, string> = {
  'roam': '漫遊',
  'walk': '行路',
  'guide': '路引'
};
const displayCategory = primaryCategory ? (categoryMap[primaryCategory.toLowerCase()] || primaryCategory) : null;
---
<Layout title={`${frontmatter.title}`} description={frontmatter.description}>

  {frontmatter.heroImage &&
    <div slot="hero" class="hero-background-container">
      <div class="hero-image" style={`background-image: url(${frontmatter.heroImage})`}></div>
      <div class="hero-overlay"></div>
    </div>
  }

  <div class="hero-foreground-content">
    {primaryCategory && <p class="hero-category">{primaryCategory}</p>}
    <h1 class="hero-title">{frontmatter.title}</h1>
  </div>

  <div class="blog-container">
    <article class="post">
      <div class="post-meta-bar">
        <div class="meta-item">
          <span class="label">日期</span>
          <span class="value">{frontmatter.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        </div>
        {primaryCategory && (
          <div class="meta-item">
            <span class="label">分類</span>
            <span class="value">
              <a href={`/categories/${primaryCategory}`} class="tag-link">{displayCategory}</a>
            </span>
          </div>
        )}
        {frontmatter.tags?.length > 0 && (
          <div class="meta-item meta-tags">
            <span class="label">標籤</span>
            <div class="tags-list">
              {frontmatter.tags.map((tag: string) => (
                <a href={`/tags/${tag}`} class="tag-link">#{tag}</a>
              ))}
            </div>
          </div>
        )}
      </div>

      <div class="content">
        <slot />
      </div>

      <!-- Comment Section -->
      <section class="comment-section">
        <h3 class="comment-title">發表評論</h3>
        <iframe 
          src={`https://comment.mountos.com/embed/area/mizuc?page_key=${encodeURIComponent(Astro.url.pathname)}&theme=light&lang=zh-TW`}
          class="comment-iframe"
          id="comment-iframe"
          loading="lazy"
          title="Comments"
        ></iframe>
      </section>
    </article>

    <script is:inline>
      window.addEventListener('message', function(event) {
        if (event.data && event.data.type === 'iframe-resize') {
          const iframe = document.getElementById('comment-iframe');
          if (iframe) {
            iframe.style.height = event.data.height + 'px';
          }
        }
      });
    </script>
    
    {hasHeadings &&
      <aside class="toc-container">
        <ToC headings={headings} />
      </aside>
    }
  </div>
</Layout>

<style>
  :global(.main-content) {
    padding: 0 !important;
    max-width: none !important;
    width: 100% !important;
    background-color: var(--color-background); /* Ensure content has a background */
    position: relative; /* Needed for z-index to work */
    z-index: 10; /* Ensure content is above the background hero */
  }

  /* --- Hero as Background --- */
  .hero-background-container {
    position: fixed; /* Fix it to the viewport */
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh; /* Full viewport height */
    z-index: -1; /* Send it to the very back */
  }
  .hero-image {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
  }
  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    /* Cinematic deep warm gradient */
    background: linear-gradient(to bottom, rgba(26,26,24,0.3) 0%, rgba(26,26,24,0.85) 100%);
  }

  /* --- Foreground Content (Title that scrolls) --- */
  .hero-foreground-content {
    color: white;
    text-align: center;
    padding: 10rem 1.5rem 5rem; /* Large padding to create space */
    position: relative;
    z-index: 5; /* Above the background hero, below main content */
  }
  .hero-category {
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0 0 1rem 0;
    opacity: 0.9;
  }
  .hero-title {
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: 0.02em;
    margin: 0;
    text-shadow: 0 4px 20px rgba(0,0,0,0.8);
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.5rem;
    }
  }

  /* --- Main Content Layout --- */
  .blog-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1.5rem;
    background-color: var(--color-background); /* White background for the scrolling part */
  }

  @media (min-width: 1024px) {
    .blog-container {
      grid-template-columns: minmax(0, 3fr) 1fr;
    }
  }

  .post {
    max-width: 720px;
    width: 100%;
    justify-self: start;
  }

  .post-meta-bar {
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    padding: 1.2rem 0;
    margin-bottom: 3.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    font-family: var(--font-serif);
  }
  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .meta-item .label {
    color: #8c8c88;
    font-size: 0.85rem;
  }
  .meta-item .value {
    color: #4a4a48;
    font-weight: 500;
  }
  .meta-tags {
    flex-grow: 1;
    justify-content: flex-end;
  }
  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .tag-link {
    color: #6a6a66;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .tag-link:hover {
    color: var(--color-text);
  }

  .content {
    font-size: 1.15rem;
    line-height: 2;
    color: var(--color-text);
    letter-spacing: 0.03em;
  }
  /* ... other styles remain the same ... */
  
  .toc-container {
    display: none;
  }
  @media (min-width: 1024px) {
    .toc-container {
      display: block;
    }
  }

  /* --- Comment Section --- */
  .comment-section {
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 2px solid rgba(0, 0, 0, 0.05);
  }
  .comment-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: #1a1a18;
    margin-bottom: 2rem;
    letter-spacing: 0.1em;
  }
  .comment-iframe {
    width: 100%;
    height: 300px; /* Initial height */
    border: none;
    overflow: hidden;
    background: transparent;
    transition: height 0.3s ease;
  }
</style>
