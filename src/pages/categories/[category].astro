
---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const allCategories = posts.flatMap(post => post.data.categories || (post.data.category ? [post.data.category] : []));
  const uniqueCategories = [...new Set(allCategories)];

  return uniqueCategories.map(category => {
    const filteredPosts = posts.filter(post => {
      const cats = post.data.categories || (post.data.category ? [post.data.category] : []);
      return cats.includes(category);
    });
    return {
      params: { category },
      props: { posts: filteredPosts },
    };
  });
}

const { category } = Astro.params;
const { posts } = Astro.props;

const categoryMap: Record<string, string> = {
  'roam': '漫遊',
  'walk': '行路',
  'guide': '路引'
};

const displayCategory = categoryMap[category.toLowerCase()] || category;
---
<Layout title={`分類：${displayCategory}`}>
  <section class="post-list">
    <h2 class="section-title">分類：{displayCategory}</h2>
    <ul>
      {posts.map(post => (
        <li>
          <a href={`/${post.slug}/`}>
            <span class="post-title">{post.data.title}</span>
            <span class="post-date">{new Date(post.data.pubDate).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
	.post-list .section-title {
		font-size: 1.8rem;
		font-family: var(--font-serif);
		font-weight: 700;
		color: #1a1a18;
		margin-bottom: 3rem;
		border-bottom: 2px solid rgba(0, 0, 0, 0.05); /* very light seal line */
		padding-bottom: 1rem;
		letter-spacing: 0.1em;
	}
	.post-list ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.post-list li a {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem;
		border-radius: 8px;
		text-decoration: none;
		color: #333;
		transition: background-color 0.2s ease;
		margin-bottom: 0.5rem;
	}
	.post-list li a:hover {
		background-color: #f5f5f5;
	}
	.post-title {
		font-family: var(--font-serif);
		font-size: 1.35rem;
		font-weight: 600;
		color: #1a1a18;
		letter-spacing: 0.03em;
	}
	.post-date {
		font-family: var(--font-serif);
		font-size: 0.9rem;
		color: #8c8c88;
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.05em;
	}
</style>
