---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Pagination from '../components/Pagination.astro';
import type { Page } from 'astro';

export async function getStaticPaths({ paginate }) {
  const allPosts = (await getCollection('blog'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(allPosts, { pageSize: 10 });
}

interface Props {
  page: Page;
}

const { page } = Astro.props;

const pageTitle = "迷走客 | Blog";
const pageDescription = `The latest news from 迷走客${page.currentPage > 1 ? ` | Page ${page.currentPage}` : ''}`;
---
<Layout title={pageTitle} description={pageDescription}>
	<section class="post-list">
		<h2>Latest Posts</h2>
		<ul>
			{page.data.map((post) => (
				<li>
					<a href={`/blog/${post.slug}/`} class="post-link">
						<span class="post-date">{post.data.pubDate.toLocaleDateString('en-US')}</span>
						<h3 class="post-title">{post.data.title}</h3>
						{post.data.description && <p class="post-description">{post.data.description}</p>}
					</a>
				</li>
			))}
		</ul>
	</section>

  <Pagination page={page} />
</Layout>

<style>
	.post-list h2 {
		font-size: 2rem;
		font-family: var(--font-serif);
		margin-bottom: 2.5rem;
		border-bottom: 1px solid var(--color-border);
		padding-bottom: 1rem;
	}
	.post-list ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.post-list li {
		margin-bottom: 2.5rem;
	}
	.post-link {
		display: block;
		text-decoration: none;
		color: var(--color-text);
		transition: opacity 0.2s ease;
	}
	.post-link:hover {
		opacity: 0.7;
	}
	.post-date {
		display: block;
		font-size: 0.85rem;
		color: #999;
		margin-bottom: 0.4rem;
		letter-spacing: 0.05em;
	}
	.post-title {
		font-family: var(--font-serif);
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0 0 0.5rem 0;
		line-height: 1.4;
	}
	.post-description {
		font-size: 1rem;
		color: #666;
		margin: 0;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
