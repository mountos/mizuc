---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Pagination from '../components/Pagination.astro';
import type { Page } from 'astro';

export async function getStaticPaths({ paginate }) {
  const allPosts = (await getCollection('blog'))
    .filter(post => !post.data.draft)
    .sort((a, b) => {
      const dateA = (a.data.pubDate || a.data.publishedDate || new Date(0)).valueOf();
      const dateB = (b.data.pubDate || b.data.publishedDate || new Date(0)).valueOf();
      return dateB - dateA;
    });
  return paginate(allPosts, { pageSize: 10 });
}

interface Props {
  page: Page;
}

const { page } = Astro.props;

const pageTitle = "MOUntos | Blog";
const pageDescription = `The latest news from MOUntos Institute${page.currentPage > 1 ? ` | Page ${page.currentPage}` : ''}`;
---
<Layout title={pageTitle} description={pageDescription}>
	<section class="post-list">
		<h2>Latest Posts</h2>
		<ul>
			{page.data.map((post) => (
				<li>
					<a href={`/blog/${post.slug}/`}>
						<span class="post-title">{post.data.title}</span>
						<span class="post-date">{new Date(post.data.pubDate || post.data.publishedDate || 0).toLocaleDateString('en-US')}</span>
					</a>
				</li>
			))}
		</ul>
	</section>

  <Pagination page={page} />
</Layout>

<style>
	.post-list h2 {
		font-size: 2rem;
		margin-bottom: 2rem;
		border-bottom: 1px solid #eee;
		padding-bottom: 1rem;
	}
	.post-list ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.post-list li a {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem;
		border-radius: 8px;
		text-decoration: none;
		color: #333;
		transition: background-color 0.2s ease;
		margin-bottom: 0.5rem;
	}
	.post-list li a:hover {
		background-color: #f5f5f5;
	}
	.post-title {
		font-size: 1.2rem;
		font-weight: 500;
	}
	.post-date {
		font-size: 0.9rem;
		color: #888;
		font-variant-numeric: tabular-nums;
	}
</style>
