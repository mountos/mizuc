---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Pagination from '../components/Pagination.astro';
import type { Page } from 'astro';

export async function getStaticPaths({ paginate }) {
  const allPosts = (await getCollection('blog'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(allPosts, { pageSize: 10 });
}

interface Props {
  page: Page;
}

const { page } = Astro.props;

const pageTitle = "迷走客 | Blog";
const pageDescription = `The latest news from 迷走客${page.currentPage > 1 ? ` | Page ${page.currentPage}` : ''}`;
---
<Layout title={pageTitle} description={pageDescription}>
	<section class="post-list">
		<h2 class="section-title">最新文章</h2>
		<ul>
			{page.data.map((post) => (
				<li>
					<a href={`/blog/${post.slug}/`} class="post-link">
						<h3 class="post-title">{post.data.title}</h3>
						<span class="post-date">{post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
						{post.data.description && <p class="post-description">{post.data.description}</p>}
					</a>
				</li>
			))}
		</ul>
	</section>

  <Pagination page={page} />
</Layout>

<style>
	.post-list .section-title {
		font-size: 1.8rem;
		font-family: var(--font-serif);
		font-weight: 700;
		color: #1a1a18;
		margin-bottom: 3rem;
		border-bottom: 2px solid rgba(0, 0, 0, 0.05); /* very light seal line */
		padding-bottom: 1rem;
		letter-spacing: 0.1em;
	}
	.post-list ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.post-list li {
		margin-bottom: 3.5rem;
	}
	.post-link {
		display: block;
		text-decoration: none;
		color: var(--color-text);
		transition: opacity 0.3s ease;
	}
	.post-link:hover {
		opacity: 0.75;
	}
	.post-date {
		display: block;
		font-family: var(--font-serif);
		font-size: 0.85rem;
		color: #8c8c88;
		margin-top: 0.5rem;
		margin-bottom: 1rem;
		letter-spacing: 0.05em;
	}
	.post-title {
		font-family: var(--font-serif);
		font-size: 1.6rem;
		font-weight: 700;
		margin: 0;
		line-height: 1.35;
		color: #1a1a18;
		letter-spacing: 0.05em;
	}
	.post-description {
		font-size: 1.05rem;
		color: #555;
		margin: 0;
		line-height: 1.8;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
